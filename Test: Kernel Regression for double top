import numpy as np
import matplotlib.pyplot as plt
from statsmodels.nonparametric.kernel_regression import KernelReg
from scipy.signal import find_peaks
import json
import websocket

# --- CONFIGURATION ---
SYMBOL = "solusdt"
LOOKBACK_SIZE = 120 
BANDWIDTH = 0.6     
SIMULATIONS = 100  # Decrease to 50 if your CPU is lagging

prices = []

def check_significance(raw_data, observed_smooth_var):
    """
    Monte Carlo Permutation Test:
    Shuffles returns to see if a random walk could produce the same signal strength.
    """
    count = 0
    returns = np.diff(raw_data)
    t_sim = np.arange(len(raw_data))
    
    for _ in range(SIMULATIONS):
        # Generate Random Walk from shuffled returns
        shuffled_returns = np.random.permutation(returns)
        rw = np.cumsum(np.insert(shuffled_returns, 0, raw_data[0]))
        
        # Smooth the Random Walk
        kr_sim = KernelReg(endog=rw, exog=t_sim, var_type='c', bw=[BANDWIDTH])
        smoothed_rw, _ = kr_sim.fit(t_sim)
        
        if np.var(smoothed_rw) >= observed_smooth_var:
            count += 1
    
    p_value = count / SIMULATIONS
    confidence = (1 - p_value) * 100
    return confidence

def run_kernel_analysis(data_window):
    t = np.arange(len(data_window))
    
    # 1. Fit Kernel to Real Data
    kr = KernelReg(endog=data_window, exog=t, var_type='c', bw=[BANDWIDTH])
    smoothed_price, _ = kr.fit(t)
    
    # 2. Calculate observed signal strength (Variance)
    observed_var = np.var(smoothed_price)
    
    # 3. Determine Significance
    conf_score = check_significance(data_window, observed_var)
    
    # --- PRINT MESSAGE LOGIC ---
    if conf_score > 90:
        print(f"[!] {SYMBOL.upper()} - SIGNIFICANT Pattern (Confidence: {conf_score:.1f}%)")
    else:
        print(f"[-] {SYMBOL.upper()} - Random Walk / Noise (Confidence: {conf_score:.1f}%)")
    
    # 4. Pattern Detection
    peaks, _ = find_peaks(smoothed_price)
    troughs, _ = find_peaks(-smoothed_price)
    
    # 5. Visuals
    plt.clf()
    plt.plot(t, data_window, alpha=0.3, color='gray', label='Raw Micro-price')
    plt.plot(t, smoothed_price, color='blue', linewidth=2, label='Kernel Signal')
    
    # Text Box for Significance
    color = 'green' if conf_score > 90 else 'red'
    status = "SIGNIFICANT" if conf_score > 90 else "NOISE/RANDOM"
    plt.text(5, np.max(data_window), f"Conf: {conf_score:.1f}% ({status})", 
             bbox=dict(facecolor=color, alpha=0.5), fontsize=10)
    
    if len(peaks) > 0: plt.scatter(t[peaks], smoothed_price[peaks], color='red', marker='v')
    if len(troughs) > 0: plt.scatter(t[troughs], smoothed_price[troughs], color='green', marker='^')
    
    plt.title(f"L2 Micro-price Analysis: {SYMBOL.upper()}")
    plt.pause(0.01)

def on_message(ws, message):
    global prices
    data = json.loads(message)
    try:
        # Standardize for Binance snapshot vs stream keys
        b = data.get('bids') or data.get('b')
        a = data.get('asks') or data.get('a')
        if b and a:
            bp, bv = float(b[0][0]), float(b[0][1])
            ap, av = float(a[0][0]), float(a[0][1])
            
            # Micro-price calculation (incorporating OBI)
            mp = (bp * av + ap * bv) / (bv + av)
            prices.append(mp)
            
            if len(prices) > LOOKBACK_SIZE:
                prices.pop(0)
                run_kernel_analysis(np.array(prices))
    except Exception as e:
        pass

# Start
plt.ion()
ws = websocket.WebSocketApp(f"wss://stream.binance.com:9443/ws/{SYMBOL}@depth5@100ms", on_message=on_message)
ws.run_forever()
