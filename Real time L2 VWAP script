import ccxt
import pandas as pd
import time

# 1. Initialize the exchange with rate limiting and error handling
# If you are in the US, change 'binance' to 'binanceus'
try:
    exchange = ccxt.binance({
        'enableRateLimit': True,
        'options': {'defaultType': 'spot'}
    })
except Exception as e:
    print(f"Initialization Error: {e}")

symbols = [
    'BTC/USDT', 'ETH/USDT', 'BNB/USDT', 'SOL/USDT', 'XRP/USDT',
    'ADA/USDT', 'DOGE/USDT', 'SUI/USDT', 'ASTR/USDT', 'AVAX/USDT'
]

def get_l2_vwap(symbol):
    try:
        # Fetch L2 Order Book (Market Depth)
        # Using a limit of 20 is often faster and less likely to trigger rate limits than 50
        order_book = exchange.fetch_order_book(symbol, limit=20)
        
        def calc_side_vwap(levels):
            total_vol = sum(level[1] for level in levels)
            weighted_sum = sum(level[0] * level[1] for level in levels)
            return weighted_sum / total_vol if total_vol > 0 else 0

        bid_vwap = calc_side_vwap(order_book['bids'])
        ask_vwap = calc_side_vwap(order_book['asks'])
        
        # Best bid and best ask for mid-price calculation
        best_bid = order_book['bids'][0][0]
        best_ask = order_book['asks'][0][0]
        mid_price = (best_bid + best_ask) / 2

        # Imbalance calculation: (Bid VWAP - Ask VWAP) relative to price
        # Positive means buy-side depth is priced higher (bullish pressure)
        imbalance = ((bid_vwap - ask_vwap) / mid_price) * 100

        return {
            'Asset': symbol.split('/')[0],
            'Mid_Price': round(mid_price, 4),
            'Bid_L2_VWAP': round(bid_vwap, 4),
            'Ask_L2_VWAP': round(ask_vwap, 4),
            'Imbalance %': f"{imbalance:.4f}%"
        }
    except Exception as e:
        # This will now print the specific error (e.g., Network, Authentication, etc.)
        return {'Asset': symbol, 'Error': str(e)[:30]} 

# 2. Execution Loop with a small delay to respect API limits
results = []
print("Fetching Market Depth Data...")

for s in symbols:
    data = get_l2_vwap(s)
    results.append(data)
    time.sleep(0.2)  # 200ms sleep between requests

# 3. Display results
df = pd.DataFrame(results)
print("\n--- L2 Order Book VWAP Analysis ---")
print(df.to_string(index=False))

